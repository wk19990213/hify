{
  "name": "hify-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint . --ext .vue,.ts,.tsx --fix",
    "lint:check": "eslint . --ext .vue,.ts,.tsx",
    "format:md": "cd .. && prettier --write \"**/*.md\" \"!hify-web/node_modules/**\"",
    "lint:md": "cd .. && markdownlint \"**/*.md\" --ignore-path .markdownlintignore"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@types/markdown-it": "^14.1.2",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/core": "^1.48.2",
    "axios": "^1.6.8",
    "dompurify": "^3.4.5",
    "element-plus": "^2.6.3",
    "markdown-it": "^14.1.1",
    "vue": "^3.4.27",
    "vue-router": "^4.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.12.12",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "jsdom": "^29.1.1",
    "markdownlint-cli": "^0.41.0",
    "prettier": "^3.3.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^4.1.7",
    "vue-tsc": "^2.0.19"
  }
}
